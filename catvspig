# ─── PLATFORM COLLISION HELPERS ───────────────────────────────────────────────
def get_platform_index(rect):
    probe = pygame.Rect(rect.x + 4, rect.bottom, rect.w - 8, 4)
    for i, p in enumerate(platforms):
        if i in (1, 2):
            continue
        if probe.colliderect(p):
            return i
    return -1

def should_start_battle(cat_rect, pig_rect):
    ci = get_platform_index(cat_rect)
    pi = get_platform_index(pig_rect)
    if ci == -1 or pi == -1 or ci != pi:
        return False
    x_touching = cat_rect.right >= pig_rect.left and pig_rect.right >= cat_rect.left
    return x_touching

def still_on_same_platform(cat_rect, pig_rect):
    ci = get_platform_index(cat_rect)
    pi = get_platform_index(pig_rect)
    return ci != -1 and ci == pi

# ─── COMBAT PRE-CALCULATION (Initiative via hit% roll) ────────────────────────
def calculate_fight(cat_start_hp=None, pig_start_hp=None, cat_stats=None, pig_stats=None):
    cs = dict(cat_stats) if cat_stats is not None else dict(CAT_STATS)
    ps = dict(pig_stats) if pig_stats is not None else dict(PIG_STATS)
    
    cat_hp  = float(cat_start_hp) if cat_start_hp is not None else float(cs["health"])
    pig_hp  = float(pig_start_hp) if pig_start_hp is not None else float(ps["health"])
    cat_max = float(cs["health"])
    pig_max = float(ps["health"])
    
    events  = []

    # === NEW INITIATIVE SYSTEM ===
    cat_speed = cs["speed"]
    pig_speed = ps["speed"]
    
    cat_hit_chance = round(cat_speed / (cat_speed + pig_speed) * 100)
    pig_hit_chance = round(pig_speed / (cat_speed + pig_speed) * 100)
    
    cat_initiative_success = random.randint(1, 100) <= cat_hit_chance
    pig_initiative_success = random.randint(1, 100) <= pig_hit_chance

    if cat_initiative_success and not pig_initiative_success:
        first = "cat"
    elif pig_initiative_success and not cat_initiative_success:
        first = "pig"
    else:
        # Both succeed or both fail → fall back to raw speed (tiebreaker)
        first = "cat" if cat_speed >= pig_speed else "pig"

    order = ([("cat", cs, ps), ("pig", ps, cs)] if first == "cat"
             else [("pig", ps, cs), ("cat", cs, ps)])

    # Rest of the fight simulation stays exactly the same
    for _ in range(30):
        if cat_hp <= 0 or pig_hp <= 0:
            break
        for aname, atk, dfn in order:
            if cat_hp <= 0 or pig_hp <= 0:
                break
            dname      = "pig" if aname == "cat" else "cat"
            strikes    = round(atk["stamina"] / dfn["stamina"]) + 1
            hit_chance = round(atk["speed"] / (atk["speed"] + dfn["speed"]) * 100)
            damage     = atk["strength"] / dfn["defense"]

            for _ in range(strikes):
                if cat_hp <= 0 or pig_hp <= 0:
                    break
                hit = random.randint(1, 100) <= hit_chance
                if hit:
                    if dname == "pig":
                        pig_hp = round(pig_hp - damage, 2)
                    else:
                        cat_hp = round(cat_hp - damage, 2)
                events.append({
                    "attacker": aname,
                    "defender": dname,
                    "hit": hit,
                    "damage": damage if hit else 0,
                    "cat_hp": cat_hp,
                    "pig_hp": pig_hp
                })

    if   cat_hp <= 0 and pig_hp <= 0: winner = "draw"
    elif cat_hp <= 0:                  winner = "pig"
    elif pig_hp <= 0:                  winner = "cat"
    else:                              winner = "draw"

    return events, winner, cat_max, pig_max
# ─── GORE + EXPLOSION SYSTEM ──────────────────────────────────────────────────
class GorePiece:
    def __init__(self, image, x, y):
        self.image      = image
        self.rect       = image.get_rect(center=(x, y))
        self.vx         = random.uniform(-5.5, 5.5)
        self.vy         = random.uniform(-9, -3)
        self.rotation   = 0
        self.rot_speed  = random.uniform(-12, 12)
        self.spawn_time = time.time()
        self.lifetime   = GORE_LIFETIME

    def update(self, platforms):
        if self.is_dead():
            return
        self.vy += 0.78
        self.rect.x += int(self.vx)
        self.rect.y += int(self.vy)
        self.vx *= 0.975
        self.rotation = (self.rotation + self.rot_speed) % 360

        for p in platforms:
            if self.rect.colliderect(p):
                if self.vx > 0 and self.rect.right > p.left:
                    self.rect.right = p.left
                    self.vx *= -0.65
                elif self.vx < 0 and self.rect.left < p.right:
                    self.rect.left = p.right
                    self.vx *= -0.65
                if self.vy > 0 and self.rect.bottom > p.top:
                    self.rect.bottom = p.top
                    self.vy *= -0.48
                    self.vx *= 0.82
                    if abs(self.vy) < 1.2:
                        self.vy = 0
                elif self.vy < 0 and self.rect.top < p.bottom:
                    self.rect.top = p.bottom
                    self.vy *= -0.4

    def is_dead(self) -> bool:
        if time.time() - self.spawn_time > self.lifetime:
            return True
        if (self.rect.right < 0 or self.rect.left > WIDTH or
                self.rect.bottom < 0 or self.rect.top > HEIGHT):
            return True
        return False

    def draw(self, screen):
        if self.is_dead():
            return
        rotated  = pygame.transform.rotate(self.image, self.rotation)
        new_rect = rotated.get_rect(center=self.rect.center)
        screen_rect = pygame.Rect(0, 0, WIDTH, HEIGHT)
        if new_rect.colliderect(screen_rect):
            screen.blit(rotated, new_rect)


class Explosion:
    def __init__(self, x: int, y: int):
        self.x          = x
        self.y          = y
        self.radius     = 5
        self.max_radius = 140
        self.alive      = True

    def update(self, objects: List[GorePiece]):
        self.radius += 9
        if self.radius > self.max_radius:
            self.alive = False
            return
        for obj in objects:
            dx   = obj.rect.centerx - self.x
            dy   = obj.rect.centery - self.y
            dist = math.hypot(dx, dy)
            if dist < self.radius and dist > 0:
                force  = (self.max_radius - dist) / self.max_radius
                nx     = dx / dist
                ny     = dy / dist
                obj.vx += nx * force * 9.5
                obj.vy += ny * force * 13.5

    def draw(self, screen):
        if not self.alive:
            return
        r = int(self.radius)
        cx, cy = int(self.x), int(self.y)
        if cx + r < 0 or cx - r > WIDTH or cy + r < 0 or cy - r > HEIGHT:
            return
        old_clip = screen.get_clip()
        screen.set_clip(pygame.Rect(0, 0, WIDTH, HEIGHT))
        pygame.draw.circle(screen, (255, 140, 30), (cx, cy), r, 3)
        pygame.draw.circle(screen, (255, 80, 20),  (cx, cy), int(self.radius * 0.6), 2)
        screen.set_clip(old_clip)


