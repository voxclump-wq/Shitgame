def load_sprite(path, target_h):
    try:
        img = pygame.image.load(path).convert_alpha()
        ow, oh = img.get_size()
        nw = max(1, int(ow * target_h / oh))
        return pygame.transform.smoothscale(img, (nw, target_h))
    except Exception:
        surf = pygame.Surface((target_h, target_h), pygame.SRCALPHA)
        col  = (100, 180, 255) if "cat" in path else (255, 160, 80)
        pygame.draw.rect(surf, col, surf.get_rect(), border_radius=10)
        lbl = font_small.render("CAT" if "cat" in path else "PIG", True, BLACK)
        surf.blit(lbl, (target_h//2 - lbl.get_width()//2,
                        target_h//2 - lbl.get_height()//2))
        return surf

