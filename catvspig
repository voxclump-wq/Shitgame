            imgs.append(surf)
    return imgs

GORE_IMGS = _load_gore_imgs()

def spawn_gore(cx, cy, count=10) -> List[GorePiece]:
    pieces = []
    for _ in range(count):
        img = random.choice(GORE_IMGS)
        ox  = cx + random.randint(-25, 25)
        oy  = cy + random.randint(-20, 20)
        pieces.append(GorePiece(img, ox, oy))
    return pieces


# ─── NAVIGATOR (now generates unique random stats on every spawn) ─────────────
class Navigator:
    def __init__(self, x, idle, walk, jump, face_right=True, is_cat=True):
        self.idle_spr     = idle
        self.walk_spr     = walk
        self.jump_spr     = jump
        h, w              = idle.get_height(), idle.get_width()
        self.rect         = pygame.Rect(x, FLOOR_Y - h, w, h)
        self.vel_x        = 0.0
        self.vel_y        = 0.0
        self.on_ground    = False
        self.facing_right = face_right
        self.direction    = 1 if face_right else -1
        self.walk_timer   = random.randint(40, 180)
        self.anim_timer   = 0
        self.show_walk    = False
        self.cur_spr      = idle

        # ── UNIQUE RANDOM STATS PER CHARACTER ───────────────────────────────
        if is_cat:
            self.stats = dict(
                strength=random.randint(1, 3),
                defense=random.randint(1, 3),
                speed=random.randint(3, 6),
                stamina=random.randint(3, 6),
                health=random.randint(3,6),
            )
        else:
            self.stats = dict(
                strength=random.randint(3, 6),
                defense=random.randint(3, 6),
                speed=random.randint(1, 3),
                stamina=random.randint(1, 3),
                health=random.randint(3,6),
            )
        self.hp_max = float(self.stats["health"])
        self.hp     = float(self.stats["health"])

    def is_visible(self) -> bool:
        """Return True only if any part of the sprite overlaps the visible game area (0,0,WIDTH,HEIGHT)."""
        screen_rect = pygame.Rect(0, 0, WIDTH, HEIGHT)
        return self.rect.colliderect(screen_rect)

    def ai_tick(self):
        if not self.on_ground:
            return
        self.walk_timer -= 1
        if self.walk_timer <= 0 or random.random() < 0.08:
            self.direction  = random.choice([-1, 1])
            self.walk_timer = random.randint(80, 220)
        self.vel_x = self.direction * MOVE_SPEED

        lx     = self.rect.centerx + (110 if self.direction > 0 else -110)
        vision = pygame.Rect(lx - 45, self.rect.y - 220, 90, 260)
        for p in platforms:
            if vision.colliderect(p) and p.top < self.rect.bottom - 30:
                if random.random() < 0.2:
                    self.vel_y     = JUMP_POWER
                    self.on_ground = False
                break

    def physics(self):
        self.vel_y += GRAVITY
        self.rect.x += int(self.vel_x)
        for p in platforms:
            if self.rect.colliderect(p):
                if self.vel_x > 0:  self.rect.right = p.left
                else:               self.rect.left  = p.right
                if p.height > 100:  self.direction  = -self.direction
                self.vel_x = 0
                break

        self.rect.y += int(self.vel_y)
        self.on_ground = False
        for p in platforms:
            if self.rect.colliderect(p):
                if self.vel_y >= 0:
                    self.rect.bottom = p.top
                    self.vel_y       = 0
                    self.on_ground   = True
                else:
                    self.rect.top = p.bottom
                    self.vel_y    = 0

        if self.rect.left  < 0:     self.rect.left  = 0;     self.direction =  1; self.vel_x = 0
        if self.rect.right > WIDTH: self.rect.right = WIDTH; self.direction = -1; self.vel_x = 0

        if not self.on_ground:
            self.cur_spr    = self.jump_spr
            self.anim_timer = 0
        elif abs(self.vel_x) > 0.5:
            self.anim_timer += 1
            if self.anim_timer >= 1:
                self.show_walk  = not self.show_walk
                self.anim_timer = 0
            self.cur_spr = self.walk_spr if self.show_walk else self.idle_spr
        else:
            self.cur_spr    = self.idle_spr
            self.anim_timer = 0

        if   self.vel_x < 0: self.facing_right = False
        elif self.vel_x > 0: self.facing_right = True

    def draw_nav(self):
        img = self.cur_spr
        if not self.facing_right:
            img = pygame.transform.flip(img, True, False)
        screen.blit(img, self.rect.topleft)


# ─── BATTLE PHASE ─────────────────────────────────────────────────────────────
class InWorldBattle:
    STEP_DELAY      = 300
    STANCE_FRAME_MS = 50
    PUNCH_FRAME_MS  = 66

    def __init__(self, cat: Navigator, pig: Navigator):
        self.cat = cat
        self.pig = pig

        cat.vel_x = 0.0
        pig.vel_x = 0.0

        # Use each character's own unique stats
        events, winner, _, _ = calculate_fight(
            cat_start_hp=cat.hp,
            pig_start_hp=pig.hp,
            cat_stats=cat.stats,
            pig_stats=pig.stats
        )
        self.events     = events
        self.winner     = winner
        self.cat_max    = cat.hp_max
        self.pig_max    = pig.hp_max
        self.cat_hp     = cat.hp
        self.pig_hp     = pig.hp

        self.event_idx  = -1
        self.timer      = 0
        self.state      = "fighting"

        self.cat_override = None
        self.pig_override = None
        self.cat_shake    = 0
        self.pig_shake    = 0

        self.atk_who   = None
        self.atk_phase = 0
        self.anim_t    = 0
        self.pend_hit  = False
        self.pend_dmg  = 0.0
        self.pend_def  = None
        self.popup     = None

        self._face_each_other()

    def _face_each_other(self):
        if self.cat.rect.centerx <= self.pig.rect.centerx:
            self.cat.facing_right = True
            self.pig.facing_right = False
        else:
            self.cat.facing_right = False
            self.pig.facing_right = True

    def update(self, dt):
        for nav in (self.cat, self.pig):
            nav.vel_y += GRAVITY
            nav.rect.y += int(nav.vel_y)
            nav.on_ground = False
            for p in platforms:
                if nav.rect.colliderect(p):
                    if nav.vel_y >= 0:
                        nav.rect.bottom = p.top
                        nav.vel_y       = 0
                        nav.on_ground   = True
                    else:
                        nav.rect.top = p.bottom
                        nav.vel_y    = 0
            nav.vel_x = 0.0

        if not still_on_same_platform(self.cat.rect, self.pig.rect):
            self.state = "cancelled"
            return

        self._face_each_other()

        if self.cat_shake:
            self.cat_shake = int(self.cat_shake * 0.65)
            if abs(self.cat_shake) < 1: self.cat_shake = 0
        if self.pig_shake:
            self.pig_shake = int(self.pig_shake * 0.65)
            if abs(self.pig_shake) < 1: self.pig_shake = 0

        if self.atk_who is not None:
            self.anim_t -= dt
            if self.anim_t <= 0:
                if self.atk_phase == 0:
                    self.atk_phase = 1
                    self.anim_t    = self.PUNCH_FRAME_MS
                    if self.atk_who == "cat":
                        self.cat_override = cat_b_punch
                    else:
                        self.pig_override = pig_b_punch

                    if self.pend_hit:
                        txt, col = f"HIT  -{self.pend_dmg:.2f}", RED
                        if self.pend_def == "pig":
                            self.pig_override = pig_b_flinch
                            self.pig_shake    = 18
                        else:
                            self.cat_override = cat_b_flinch
                            self.cat_shake    = -18
                    else:
                        txt, col = "MISS", YELLOW

                    def_nav = self.pig if self.pend_def == "pig" else self.cat
                    self.popup = {
                        "text": txt, "colour": col,
                        "wx":   def_nav.rect.centerx,
                        "wy":   def_nav.rect.top - 28,
                        "age": 0, "duration": self.STEP_DELAY - 80,
                    }
                else:
                    self.cat_override = None
                    self.pig_override = None
                    self.atk_who      = None
                    self.atk_phase    = 0
                    self.pend_hit     = False

        if self.popup:
            self.popup["age"] += dt
            if self.popup["age"] > self.popup["duration"]:
                self.popup = None

        self.timer += dt
        if self.timer >= self.STEP_DELAY:
            self.timer = 0
            self._next_event()

    def _next_event(self):
        self.event_idx += 1
        if self.event_idx >= len(self.events):
            self.state = "done"
            return
        ev             = self.events[self.event_idx]
        self.cat_hp    = ev["cat_hp"]
        self.pig_hp    = ev["pig_hp"]
        self.atk_who   = ev["attacker"]
        self.atk_phase = 0
        self.anim_t    = self.STANCE_FRAME_MS
        if self.atk_who == "cat":
            self.cat_override = cat_b_stance
            self.pig_override = None
        else:
            self.cat_override = None
            self.pig_override = pig_b_stance
        self.pend_hit = ev["hit"]
        self.pend_dmg = ev["damage"]
        self.pend_def = ev["defender"]

    def draw(self):
        # NEW: Skip drawing if both characters are completely off-screen
        if not (self.cat.is_visible() or self.pig.is_visible()):
            return

        pig_faces_left = self.pig.rect.centerx >= self.cat.rect.centerx
        flip_map = {pig_b_idle: pig_b_idle_f, pig_b_stance: pig_b_stance_f,
                    pig_b_punch: pig_b_punch_f, pig_b_flinch: pig_b_flinch_f}

        raw_cat = self.cat_override if self.cat_override else cat_b_idle
        cat_img = raw_cat if self.cat.facing_right else pygame.transform.flip(raw_cat, True, False)
        screen.blit(cat_img, (self.cat.rect.x + self.cat_shake, self.cat.rect.y))

        raw_pig   = self.pig_override if self.pig_override else pig_b_idle
        pig_faced = flip_map.get(raw_pig, pig_b_idle_f)
        if not pig_faces_left:
            pig_faced = pygame.transform.flip(pig_faced, True, False)
        screen.blit(pig_faced, (self.pig.rect.x + self.pig_shake, self.pig.rect.y))

        BAR_W = HEALTH_BAR_W
        BAR_H = HEALTH_BAR_H
        cat_bx = max(4, min(self.cat.rect.centerx - BAR_W//2, WIDTH - BAR_W - 4))
        pig_bx = max(4, min(self.pig.rect.centerx - BAR_W//2, WIDTH - BAR_W - 4))
        cat_by = max(22, self.cat.rect.top - 36)
        pig_by = max(22, self.pig.rect.top - 36)
        draw_health_bar(cat_bx, cat_by, BAR_W, BAR_H, self.cat_hp, self.cat_max, "")
        draw_health_bar(pig_bx, pig_by, BAR_W, BAR_H, self.pig_hp, self.pig_max, "")

        if self.popup:
            frac  = self.popup["age"] / max(1, self.popup["duration"])
            alpha = max(0, int(255 * (1.0 - frac)))
            surf  = pygame.Surface((220, 32), pygame.SRCALPHA)
            surf.blit(font_med.render(self.popup["text"], True, (0, 0, 0, alpha)), (2, 2))
            surf.blit(font_med.render(self.popup["text"], True,
                                      (*self.popup["colour"], alpha)), (0, 0))
            screen.blit(surf, (self.popup["wx"] - surf.get_width()//2,
                                self.popup["wy"] - int(22 * frac)))


# ─── MAIN ─────────────────────────────────────────────────────────────────────
def main():
    cat_nav = Navigator(60,          cat_nav_idle, cat_nav_walk, cat_nav_jump, face_right=True,  is_cat=True)
    pig_nav = Navigator(WIDTH - 100, pig_nav_idle, pig_nav_walk, pig_nav_jump, face_right=False, is_cat=False)

    battles      : list[InWorldBattle] = []
    gore_pieces  : List[GorePiece]     = []
    explosions   : List[Explosion]     = []

    # ── BUTTON LAYOUT ───────────────────────────────────────────────────────────
    # Horizontal layout with 100px spacing: Cat -- Both -- Pig, centered under game
    BTN_SIZE = 110
    GAP      = 100                    # 100 pixel space between each button
    BTN_Y    = HEIGHT + 40            # vertical position of the entire button row

    # Auto-calculate centered positions
    total_width = BTN_SIZE * 3 + GAP * 2
    start_x = (WIDTH - total_width) // 2

    btn_cat  = pygame.Rect(start_x,                          BTN_Y, BTN_SIZE, BTN_SIZE)
    btn_both = pygame.Rect(start_x + BTN_SIZE + GAP,         BTN_Y, BTN_SIZE, BTN_SIZE)
    btn_pig  = pygame.Rect(start_x + (BTN_SIZE + GAP) * 2,   BTN_Y, BTN_SIZE, BTN_SIZE)

    cats : list[Navigator] = [cat_nav]
    pigs : list[Navigator] = [pig_nav]

    while True:
        dt = clock.tick(FPS)

        for ev in pygame.event.get():
            if ev.type == pygame.QUIT:
                pygame.quit(); sys.exit()
            if ev.type == pygame.MOUSEBUTTONDOWN and ev.button == 1:
                mx, my = ev.pos
                if btn_cat.collidepoint(mx, my):
                    cats.append(Navigator(random.randint(40, WIDTH - 40),
                                          cat_nav_idle, cat_nav_walk,
                                          cat_nav_jump, face_right=True, is_cat=True))
                if btn_pig.collidepoint(mx, my):
                    pigs.append(Navigator(random.randint(40, WIDTH - 40),
                                          pig_nav_idle, pig_nav_walk,
                                          pig_nav_jump, face_right=False, is_cat=False))
                if btn_both.collidepoint(mx, my):
                    # Spawn one cat + one pig at random positions
                    cats.append(Navigator(random.randint(40, WIDTH - 40),
                                          cat_nav_idle, cat_nav_walk,
                                          cat_nav_jump, face_right=True, is_cat=True))
                    pigs.append(Navigator(random.randint(40, WIDTH - 40),
                                          pig_nav_idle, pig_nav_walk,
                                          pig_nav_jump, face_right=False, is_cat=False))

        draw_bg()
        draw_platforms()

        def fighting_ids():
            ids = set()
            for b in battles:
                if b.state == "fighting":
                    ids.add(id(b.cat))
                    ids.add(id(b.pig))
            return ids

        finished = []
        for b in battles:
            b.update(dt)
            if b.state == "cancelled":
                finished.append(b)
                continue

            b.draw()

            if b.state == "done":
                if b.winner in ("pig", "draw"):
                    if b.cat in cats:
                        cats.remove(b.cat)
                    cx, cy = b.cat.rect.centerx, b.cat.rect.centery
                    gore_pieces.extend(spawn_gore(cx, cy, count=12))
                    explosions.append(Explosion(cx, cy))

                if b.winner in ("cat", "draw"):
                    if b.pig in pigs:
                        pigs.remove(b.pig)
                    cx, cy = b.pig.rect.centerx, b.pig.rect.centery
                    gore_pieces.extend(spawn_gore(cx, cy, count=12))
                    explosions.append(Explosion(cx, cy))

                if b.winner != "pig":
                    b.cat.hp = b.cat_hp
                    b.cat.walk_timer = random.randint(40, 180)
                if b.winner != "cat":
                    b.pig.hp = b.pig_hp
                    b.pig.walk_timer = random.randint(40, 180)

                finished.append(b)

        for b in finished:
            battles.remove(b)

        busy = fighting_ids()
        for nav in cats + pigs:
            if id(nav) in busy:
                continue
            nav.ai_tick()
            nav.physics()
            if nav.is_visible():   # ← This now works and skips invisible drawing
                nav.draw_nav()
                if nav.hp_max > 0:
                    BAR_W = HEALTH_BAR_W
                    BAR_H = HEALTH_BAR_H
                    bx = max(4, min(nav.rect.centerx - BAR_W // 2, WIDTH - BAR_W - 4))
                    by = max(22, nav.rect.top - 36)
                    draw_health_bar(bx, by, BAR_W, BAR_H, nav.hp, nav.hp_max, "")

        busy = fighting_ids()
        for c in cats:
            if id(c) in busy:
                continue
            for p in pigs:
                if id(p) in busy:
                    continue
                if should_start_battle(c.rect, p.rect):
                    battles.append(InWorldBattle(c, p))
                    busy.add(id(c))
                    busy.add(id(p))
                    break

        for g in gore_pieces:
            g.update(platforms)
        for e in explosions:
            e.update(gore_pieces)
        gore_pieces = [g for g in gore_pieces if not g.is_dead()]
        explosions  = [e for e in explosions if e.alive]

        for g in gore_pieces:
            g.draw(screen)
        for e in explosions:
            e.draw(screen)

        # ── UI AREA (underneath the game) ─────────────────────────────────────────
        pygame.draw.rect(screen, DARK, (0, HEIGHT, WIDTH, UI_HEIGHT))   # dark UI strip

        # Cat button (left)
        pygame.draw.rect(screen, (230, 200, 40), btn_cat, border_radius=12)
        pygame.draw.rect(screen, BLACK, btn_cat, 4, border_radius=12)
        lbl_cat = font_med.render("+ Cat", True, BLACK)
        screen.blit(lbl_cat, (btn_cat.centerx - lbl_cat.get_width()//2,
                              btn_cat.centery - lbl_cat.get_height()//2))

        # Both button (middle)
        pygame.draw.rect(screen, (100, 220, 100), btn_both, border_radius=12)
        pygame.draw.rect(screen, BLACK, btn_both, 4, border_radius=12)
        lbl_both = font_med.render("+ Both", True, BLACK)
        screen.blit(lbl_both, (btn_both.centerx - lbl_both.get_width()//2,
                               btn_both.centery - lbl_both.get_height()//2))

        # Pig button (right)
        pygame.draw.rect(screen, (220, 80, 160), btn_pig, border_radius=12)
        pygame.draw.rect(screen, BLACK, btn_pig, 4, border_radius=12)
        lbl_pig = font_med.render("+ Pig", True, BLACK)
        screen.blit(lbl_pig, (btn_pig.centerx - lbl_pig.get_width()//2,
                              btn_pig.centery - lbl_pig.get_height()//2))

        pygame.display.flip()

if __name__ == "__main__":
    main()