def draw_health_bar(x, y, w, h, current, maximum, name):
    ratio  = max(0.0, current / maximum)
    colour = GREEN if ratio > 0.5 else (YELLOW if ratio > 0.25 else RED)
    pygame.draw.rect(screen, DARK,   (x-2, y-2, w+4, h+4), border_radius=4)
    pygame.draw.rect(screen, GREY,   (x,   y,   w,   h),   border_radius=4)
